{
  "name": "backend-nitro-postgres",
  "version": "1.0.0",
  "description": "A well-documented backend application built with Nitro and PostgreSQL with database migrations",
  "type": "module",
  "scripts": {
    "dev": "nitro dev",
    "build": "nitro build",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "drizzle-kit push:pg",
    "migrate:generate": "drizzle-kit generate:pg",
    "migrate:down": "node src/migrations/rollback.js",
    "studio": "drizzle-kit studio"
  },
  "keywords": [
    "nitro",
    "postgresql",
    "backend",
    "api",
    "drizzle",
    "migrations"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@neondatabase/serverless": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.28.6",
    "h3": "^1.8.2",
    "jsonwebtoken": "^9.0.2",
    "nitropack": "^2.6.3",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.8.4",
    "@types/pg": "^8.10.3",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "drizzle-kit": "^0.19.13",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "nitro": "^2.6.3",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6"
  }
}

